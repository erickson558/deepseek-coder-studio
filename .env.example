LLM_APP_NAME=DeepSeek Coder Studio
LLM_ENV=development
LLM_HOST=0.0.0.0
LLM_PORT=8000
LLM_LOG_LEVEL=INFO
LLM_DEFAULT_MODEL_ID=deepseek-coder-v2-lite-instruct
LLM_BASE_MODEL_NAME=deepseek-ai/DeepSeek-Coder-V2-Lite-Instruct
LLM_MODEL_SOURCE=adapter
LLM_ADAPTER_PATH=outputs/adapters/latest
LLM_MERGED_MODEL_PATH=outputs/merged/latest
LLM_DEVICE=auto
LLM_DEFAULT_TEMPERATURE=0.2
LLM_DEFAULT_MAX_NEW_TOKENS=512
LLM_REQUEST_TIMEOUT_SECONDS=120
LLM_API_KEY=
LLM_ALLOW_ORIGINS=["*"]
